<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title - Admin Panel</title>

    <!-- Tailwind -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
</head>

<body class="bg-gray-100 font-sans">

    <div class="flex min-h-screen">

        <!-- 🔥 Sidebar -->
        <aside id="sidebar" class="bg-gradient-to-b from-teal-800 to-teal-900 text-white w-64 transition-all duration-300 flex flex-col">

            <!-- Logo -->
            <div class="p-4 border-b border-teal-700 flex items-center justify-between">
                <span id="logoText" class="text-xl font-bold">DevPanel</span>
                <button onclick="toggleSidebar()">
                    <i class="fa fa-bars"></i>
                </button>
            </div>

            <!-- Menu -->
            <ul class="flex-1 p-3 space-y-2 text-sm">

                <li class="menu-item flex items-center gap-3 p-2 rounded hover:bg-teal-700 cursor-pointer">
                    <i class="fa fa-home w-5 text-center"></i>
                    <span class="menu-text">Dashboard</span>
                </li>

                <li class="menu-item flex items-center gap-3 p-2 rounded hover:bg-teal-700 cursor-pointer">
                    <i class="fa fa-users w-5 text-center"></i>
                    <span class="menu-text">Users</span>
                </li>

                <li class="menu-item flex items-center gap-3 p-2 rounded hover:bg-teal-700 cursor-pointer">
                    <i class="fa fa-tasks w-5 text-center"></i>
                    <span class="menu-text">Tasks</span>
                </li>

                <li class="menu-item flex items-center gap-3 p-2 rounded hover:bg-teal-700 cursor-pointer">
                    <i class="fa fa-cog w-5 text-center"></i>
                    <span class="menu-text">Settings</span>
                </li>

            </ul>

            <!-- Footer -->
            <div class="p-3 border-t border-teal-700 text-xs text-gray-300 text-center">
                © 2026 DevPanel
            </div>

        </aside>

        <!-- 🔥 Main -->
        <div class="flex-1 flex flex-col">

            <!-- 🔥 Navbar -->
            <header class="bg-white shadow px-6 py-3 flex justify-between items-center">

                <!-- Left -->
                <h1 class="text-lg font-semibold">@ViewBag.Title</h1>

                <!-- Right -->
                <div class="flex items-center gap-6">

                    <!-- Search -->
                    <div class="hidden md:flex items-center bg-gray-100 px-3 py-1 rounded">
                        <i class="fa fa-search text-gray-500"></i>
                        <input type="text" placeholder="Search..." class="bg-transparent outline-none ml-2 text-sm" />
                    </div>

                    <!-- Notification -->
                    <div class="relative cursor-pointer">
                        <i class="fa fa-bell text-lg"></i>
                        <span class="absolute -top-2 -right-2 bg-red-500 text-white text-xs px-1 rounded-full">3</span>
                    </div>

                    <!-- Profile -->
                    <div class="relative">

                        <div onclick="toggleDropdown()" class="flex items-center gap-2 cursor-pointer">
                            <img src="https://i.pravatar.cc/40" class="rounded-full w-8 h-8" />
                            <span class="hidden md:block text-sm font-medium">Radhika</span>
                            <i class="fa fa-angle-down text-sm"></i>
                        </div>

                        <!-- Dropdown -->
                        <div id="dropdown" class="hidden absolute right-0 mt-2 w-44 bg-white shadow-lg rounded-lg overflow-hidden">

                            <a href="#" class="block px-4 py-2 hover:bg-gray-100 text-sm">
                                <i class="fa fa-user mr-2"></i> Profile
                            </a>

                            <a href="#" class="block px-4 py-2 hover:bg-gray-100 text-sm">
                                <i class="fa fa-cog mr-2"></i> Settings
                            </a>

                            <a href="#" class="block px-4 py-2 hover:bg-red-100 text-red-600 text-sm">
                                <i class="fa fa-sign-out-alt mr-2"></i> Logout
                            </a>

                        </div>

                    </div>

                </div>

            </header>

            <!-- 🔥 Page Content -->
            <main class="p-6">
                @RenderBody()
            </main>

        </div>

    </div>

    <!-- 🔥 Scripts -->
    <script>

        function toggleSidebar() {
            let sidebar = document.getElementById("sidebar");
            let texts = document.querySelectorAll(".menu-text");
            let logo = document.getElementById("logoText");

            sidebar.classList.toggle("w-64");
            sidebar.classList.toggle("w-20");

            texts.forEach(t => t.classList.toggle("hidden"));
            logo.classList.toggle("hidden");
        }

        function toggleDropdown() {
            document.getElementById("dropdown").classList.toggle("hidden");
        }

    </script>

</body>
</html>