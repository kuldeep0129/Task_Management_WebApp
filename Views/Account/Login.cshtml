@model Task_Management_Web.Dto.LoginDto
@using Task_Management_Web.Enum

@{
    ViewData["Title"] = "Login";
}

<style>
    .login-card {
        width: 100%;
        max-width: 400px;
        border-radius: 15px;
    }

    body {
        background: linear-gradient(135deg, #667eea, #764ba2);
    }
</style>

<div class="d-flex justify-content-center align-items-center vh-100 bg-light">

    <div class="card shadow-lg p-4 login-card">

        <div class="text-center mb-3">
            <h3 class="fw-bold">🔐 Login</h3>
            <p class="text-muted">Access your account</p>
        </div>

        <form asp-action="LoginUser" method="post" asp-controller="Account">

            <!-- Email -->
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="Enter email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <!-- Password -->
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Enter password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>


            <!-- Button -->
            <div class="d-grid">
                <button type="submit" class="btn btn-primary">Login</button>
            </div>

        </form>

    </div>

</div>