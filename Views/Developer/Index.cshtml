@{
    Layout = "~/Views/Shared/_DeveloperLayout.cshtml";
    ViewBag.Title = "Developer Dashboard";
}

<div class="space-y-6">

    <!-- 🔥 Stats Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

        <div onclick="openTaskModal('UI Design','Radhika','Completed','Today')"
             class="bg-white p-5 rounded-xl shadow hover:shadow-lg transition cursor-pointer">
            <div class="flex justify-between items-center">
                <div>
                    <p class="text-gray-500">Completed Tasks</p>
                    <h2 class="text-2xl font-bold text-green-600">80</h2>
                </div>
                <i class="fa fa-check-circle text-3xl text-green-500"></i>
            </div>
        </div>

        <div onclick="openTaskModal('API Integration','Kuldeep','Pending','Yesterday')"
             class="bg-white p-5 rounded-xl shadow hover:shadow-lg transition cursor-pointer">
            <div class="flex justify-between items-center">
                <div>
                    <p class="text-gray-500">Pending Tasks</p>
                    <h2 class="text-2xl font-bold text-red-600">25</h2>
                </div>
                <i class="fa fa-clock text-3xl text-red-500"></i>
            </div>
        </div>

        <div class="bg-white p-5 rounded-xl shadow">
            <div class="flex justify-between items-center">
                <div>
                    <p class="text-gray-500">Total Projects</p>
                    <h2 class="text-2xl font-bold text-blue-600">45</h2>
                </div>
                <i class="fa fa-folder text-3xl text-blue-500"></i>
            </div>
        </div>

        <div class="bg-white p-5 rounded-xl shadow">
            <div class="flex justify-between items-center">
                <div>
                    <p class="text-gray-500">Total Users</p>
                    <h2 class="text-2xl font-bold text-teal-600">120</h2>
                </div>
                <i class="fa fa-users text-3xl text-teal-500"></i>
            </div>
        </div>

    </div>

    <!-- 📊 Charts -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <div class="bg-white p-5 rounded-xl shadow">
            <h3 class="font-semibold mb-3">Task Overview</h3>
            <canvas id="taskPie"></canvas>
        </div>

        <div class="bg-white p-5 rounded-xl shadow">
            <h3 class="font-semibold mb-3">Weekly Progress</h3>
            <canvas id="taskBar"></canvas>
        </div>

    </div>

    <!-- 📋 Table -->
    <div class="bg-white p-5 rounded-xl shadow">
        <h3 class="font-semibold mb-4">Recent Activities</h3>

        <table class="w-full text-left">
            <thead>
                <tr class="border-b">
                    <th class="p-2">Task</th>
                    <th class="p-2">User</th>
                    <th class="p-2">Status</th>
                    <th class="p-2">Date</th>
                </tr>
            </thead>

            <tbody>
                <tr onclick="openTaskModal('UI Design','Radhika','Completed','Today')"
                    class="border-b hover:bg-gray-50 cursor-pointer">
                    <td class="p-2">UI Design</td>
                    <td class="p-2">Radhika</td>
                    <td class="p-2 text-green-500">Completed</td>
                    <td class="p-2">Today</td>
                </tr>

                <tr onclick="openTaskModal('API Integration','Kuldeep','Pending','Yesterday')"
                    class="border-b hover:bg-gray-50 cursor-pointer">
                    <td class="p-2">API Integration</td>
                    <td class="p-2">Kuldeep</td>
                    <td class="p-2 text-yellow-500">Pending</td>
                    <td class="p-2">Yesterday</td>
                </tr>
            </tbody>
        </table>
    </div>
   
</div>

<!-- 🔥 MODAL -->

<div id="taskModal" class="fixed inset-0 bg-black bg-opacity-40 hidden justify-center items-center z-50">

   
    <div class="bg-white w-full max-w-md rounded-xl shadow-lg p-6 relative">

        <button onclick="closeModal()" class="absolute top-3 right-3 text-gray-500">
            <i class="fa fa-times"></i>
        </button>

        <h2 class="text-xl font-semibold mb-4">Task Details</h2>

        <div class="space-y-3 text-sm">
            <p><strong>Task:</strong> <span id="taskName"></span></p>
            <p><strong>Assigned By:</strong> <span id="taskUser"></span></p>
            <p><strong>Date:</strong> <span id="taskDate"></span></p>

            <div>
                <label class="block mb-1 font-medium">Status</label>
                <select id="taskStatus" class="w-full border p-2 rounded">
                    <option>Pending</option>
                    <option>In Progress</option>
                    <option>Completed</option>
                </select>
            </div>
        </div>

        <div class="mt-5 flex justify-end gap-3">
            <button onclick="closeModal()" class="px-4 py-2 bg-gray-200 rounded">Cancel</button>
            <button onclick="saveStatus()" class="px-4 py-2 bg-teal-600 text-white rounded">Save</button>
        </div>

    </div>
  

</div>

<!-- Chart.js -->

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    function openTaskModal(name, user, status, date) {
        document.getElementById("taskName").innerText = name;
        document.getElementById("taskUser").innerText = user;
        document.getElementById("taskDate").innerText = date;
        document.getElementById("taskStatus").value = status;
        document.getElementById("taskModal").classList.remove("hidden");
        document.getElementById("taskModal").classList.add("flex");
    }

    function closeModal() {
        document.getElementById("taskModal").classList.add("hidden");
    }

    function saveStatus() {
        let status = document.getElementById("taskStatus").value;
        alert("Status Updated to: " + status);
        closeModal();
    }

    // Charts
    new Chart(document.getElementById('taskPie'), {
        type: 'doughnut',
        data: {
            labels: ['Completed', 'Pending'],
            datasets: [{
                data: [80, 25],
                backgroundColor: ['#10B981', '#EF4444']
            }]
        }
    });

    new Chart(document.getElementById('taskBar'), {
        type: 'bar',
        data: {
            labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri'],
            datasets: [{
                label: 'Tasks',
                data: [5, 8, 6, 10, 7],
                backgroundColor: '#3B82F6'
            }]
        }
    });

</script>
